  "description": "Planning SaaS multi-établissements — avec authentification",
  "main": "server.js",
  "scripts": {
    "start": "node -e \"const fs=require('fs');const sw=fs.readFileSync('public/sw.js','utf8').replace('%%BUILD_TIME%%', Date.now());fs.writeFileSync('public/sw.js',sw);\" && node server.js",
    "dev": "node --watch server.js",
    "init": "node scripts/init-db.js",
    "seed": "node scripts/seed.js",
    "create-patron": "node scripts/create-patron.js",
    "lint": "eslint .",
    "test": "node --test tests/utils.test.js tests/shift-hours.test.js tests/week.test.js tests/routes.test.js tests/conges.test.js"
  },
  "license": "ISC",
